{
  "rewrites": [
    {
      "source": "/api/upcitemdb/:path*",
      "destination": "https://api.upcitemdb.com/prod/trial/:path*"
    },
    {
      "source": "/api/discogs/:path*",
      "destination": "https://api.discogs.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
